      "source": [
        "# Step 3: Build one row per incident\n",
        "#   - FEATURES come from the FIRST row (what's known at ticket creation)\n",
        "#   - LABELS come from the LAST row (final outcome)\n",
        "#\n",
        "# But first we need a reliable way to know which row is \"first\" and which\n",
        "# is \"last\" for each incident, since the raw file isn't guaranteed to be\n",
        "# in chronological order. sys_mod_count looks like an event counter\n",
        "# (0, 1, 2, 3...) that increases as the incident progresses, so we sort by it.\n",
        "\n",
        "df_sorted = df.sort_values(['number', 'sys_mod_count'])\n",
        "\n",
        "first_rows = df_sorted.groupby('number', as_index=False).first()\n",
        "last_rows = df_sorted.groupby('number', as_index=False).last()\n",
        "\n",
        "print(\"First rows shape:\", first_rows.shape)\n",
        "print(\"Last rows shape:\", last_rows.shape)\n",
        "\n",
        "# Sanity check: sys_mod_count in first_rows should mostly be 0 (start of life)\n",
        "print(first_rows['sys_mod_count'].value_counts().head())\n",
        "\n",
        "# Sanity check: sys_mod_count in last_rows should be higher / varied (end of life)\n",
        "print(last_rows['sys_mod_count'].describe())"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 4: Select feature columns from first_rows, label columns from last_rows\n",
        "\n",
        "# Features: known at ticket creation. Based on what we found in Step 2:\n",
        "#   - priority, urgency, impact, category: barely change after creation -> safe\n",
        "#   - assignment_group: changes in 45% of incidents, but first-row value\n",
        "#     still reflects a real intake decision (which team it was first sent to)\n",
        "#   - contact_type, location, subcategory, u_symptom, opened_by, opened_at,\n",
        "#     knowledge: haven't checked variation on these yet, but they're\n",
        "#     intake-time fields by nature (how the ticket came in, who reported it,\n",
        "#     when) -> including them, flag for a variation check if you want one first\n",
        "#   - reassignment_count, incident_state: EXCLUDED (Step 2 showed these\n",
        "#     carry no real signal at intake time)\n",
        "\n",
        "feature_cols = [\n",
        "    'number',            # keep as an ID to join back to labels / Power BI later\n",
        "    'contact_type', 'location', 'category', 'subcategory', 'u_symptom',\n",
        "    'impact', 'urgency', 'priority', 'assignment_group', 'knowledge',\n",
        "    'opened_by', 'opened_at'\n",
        "]\n",
        "\n",
        "features = first_rows[feature_cols].copy()\n",
        "\n",
        "# Labels: final outcome, from last_rows\n",
        "labels = last_rows[['number', 'made_sla', 'reopen_count']].copy()\n",
        "\n",
        "print(features.shape)\n",
        "print(features.head())\n",
        "print(labels.shape)\n",
        "print(labels.head())"
