    {
      "cell_type": "code",
      "source": [
        "# For each incident, check which columns actually change across its rows.\n",
        "# Columns that vary = they evolve over the incident's life (can't trust an\n",
        "# arbitrary row's value for these — need first row for features, last row for labels).\n",
        "# Columns that never vary = fixed at creation, safe to use directly.\n",
        "\n",
        "cols_to_check = [\n",
        "    'made_sla', 'reopen_count', 'reassignment_count', 'incident_state',\n",
        "    'priority', 'category', 'assignment_group', 'urgency', 'impact'\n",
        "]\n",
        "\n",
        "variation_summary = {}\n",
        "for col in cols_to_check:\n",
        "    n_unique_per_incident = df.groupby('number')[col].nunique()\n",
        "    pct_incidents_that_vary = (n_unique_per_incident > 1).mean()\n",
        "    variation_summary[col] = round(pct_incidents_that_vary * 100, 2)\n",
        "\n",
        "for col, pct in variation_summary.items():\n",
        "    print(f\"{col}: varies within {pct}% of incidents\")"
      ],
